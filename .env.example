# Required
OPENAI_API_KEY=sk-...
ORACLE_SCAN_ROOT=/path/to/your/repos

# Optional — for Claude-powered answers (falls back to OpenAI if not set)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — override defaults
