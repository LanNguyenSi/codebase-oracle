# Required
OPENAI_API_KEY=sk-...
ORACLE_SCAN_ROOT=/path/to/your/repos

# Optional — for Claude-powered answers (falls back to OpenAI if not set)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — provider selection
# ORACLE_EMBEDDING_PROVIDER=openai   # openai | ollama
# ORACLE_LLM_PROVIDER=auto           # auto | anthropic | openai | ollama
#
# Optional — OpenAI-compatible endpoints (e.g. proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Optional — Ollama (used when *_PROVIDER=ollama)
# OLLAMA_API_KEY=ollama
# ORACLE_OLLAMA_BASE_URL=http://localhost:11434/v1
#
# Optional — override defaults
# ORACLE_DATA_DIR=~/.codebase-oracle
# ORACLE_EMBEDDING_MODEL=text-embedding-3-small   # OpenAI default, Ollama default: nomic-embed-text
# ORACLE_LLM_MODEL=claude-sonnet-4-20250514       # OpenAI default: gpt-4o-mini, Ollama default: llama3.1
# ORACLE_VECTOR_STORE=directory
